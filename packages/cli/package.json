{
  "name": "profil",
  "version": "0.1.0-dev.0",
  "description": "AI-managed portfolio / knowledge base / per-position resume site — internal CLI (init/check/add/list/remove/clean)",
  "keywords": ["resume", "cv", "portfolio", "obsidian", "markdown", "cli"],
  "license": "MIT",
  "homepage": "https://github.com/jyje/profil",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jyje/profil.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "profil": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": ["dist/cli.js", "templates"],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsc -b",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node24 --external:yaml --banner:js=\"import{createRequire}from'node:module';const require=createRequire(import.meta.url);\" --outfile=dist/cli.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run bundle"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "esbuild": "^0.28.1",
    "gray-matter": "^4.0.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  }
}
